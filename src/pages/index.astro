---
import Layout from '../layouts/Layout.astro';
---
<Layout title="情侶習慣追蹤">
  <div class="min-h-screen flex flex-col items-center justify-center px-6 py-12">
    <div class="w-20 h-20 rounded-full flex items-center justify-center mb-6" style="background:linear-gradient(135deg,var(--color-me),var(--color-accent))">
      <span class="text-4xl">♡</span>
    </div>
    <h1 class="text-2xl font-bold text-dark mb-1">情侶習慣追蹤</h1>
    <p class="text-gray-text text-sm mb-8">一起養成好習慣</p>

    <form id="login-form" class="w-full space-y-4 mb-6">
      <div>
        <label class="block text-sm font-semibold mb-1.5">Email</label>
        <input type="email" id="l-email" class="form-input" placeholder="email@example.com" />
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5">密碼</label>
        <input type="password" id="l-pass" class="form-input" placeholder="至少 6 個字元" />
      </div>
      <div id="l-error" class="text-sm text-center" style="color:var(--color-red);display:none"></div>
      <button type="submit" class="btn-gradient mt-4" id="l-btn">登入</button>
    </form>

    <p class="text-gray-text text-sm">與你的另一半一起成長 💕</p>
  </div>

  <script is:inline>
    // Check if already logged in
    (async()=>{
      if(localStorage.getItem('habits_token')){
        const ok=await SB.init();
        if(ok&&SB.myProfile)window.location.href='/habits';
      }
    })();

    document.getElementById('login-form').addEventListener('submit',async function(e){
      e.preventDefault();
      const btn=document.getElementById('l-btn');
      const err=document.getElementById('l-error');
      err.style.display='none';
      btn.textContent='登入中...';btn.disabled=true;
      const email=document.getElementById('l-email').value.trim();
      const password=document.getElementById('l-pass').value;
      try{
        await SB.login(email,password);
        window.location.href='/habits';
      }catch(ex){
        err.textContent=ex.message||'登入失敗';err.style.display='';
        btn.textContent='登入';btn.disabled=false;
      }
    });
  </script>
</Layout>
