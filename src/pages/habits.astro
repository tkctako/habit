---
import Layout from '../layouts/Layout.astro';
---
<Layout title="習慣追蹤">
  <div class="flex items-center justify-between px-5 py-3.5 bg-card border-b border-gray-mid">
    <h1 class="text-lg font-bold text-dark" style="font-family:'Cormorant Garamond','Noto Sans TC',serif;letter-spacing:0.02em">習慣追蹤</h1>
    <div class="flex items-center gap-3">
      <span id="user-greeting" class="text-sm font-semibold text-dark"></span>
      <button onclick="openUserModal()" class="flex items-center justify-center" style="background:none;border:none;cursor:pointer;width:28px;height:28px;color:var(--color-accent)" id="user-icon-btn"></button>
      <button onclick="SB.signOut()" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-mid bg-transparent text-gray-text cursor-pointer" style="font-family:'Noto Sans TC',sans-serif">登出</button>
    </div>
  </div>

  <div class="px-4 pt-4">
    <div id="banner-cover" class="cover-container">
      <img id="banner-img" src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800&h=400&fit=crop" draggable="false" />
      <div class="cover-controls">
        <input type="range" min="100" max="300" value="100" class="cover-zoom" id="banner-zoom" title="縮放" />
        <label class="cursor-pointer"><span class="cam-icon"></span><input type="file" accept="image/*" id="banner-file" class="hidden" /></label>
        <button id="banner-url-btn" title="網址"><span class="link-icon"></span></button>
      </div>
    </div>
  </div>

  <!-- Invite code banner -->
  <div id="invite-banner" class="mx-4 mt-3 rounded-2xl p-3 text-center text-sm" style="background:var(--color-me-light);display:none">
    <span class="text-gray-text">你的配對碼：</span>
    <span id="invite-code" class="font-bold" style="color:var(--color-accent);letter-spacing:0.15em"></span>
    <span class="text-gray-text">（分享給另一半）</span>
  </div>

  <div class="px-4 pt-4 pb-2">
    <div class="flex rounded-2xl overflow-hidden border border-gray-mid">
      <button id="tab-today" class="flex-1 py-3 text-sm font-semibold flex items-center justify-center gap-2 tab-active rounded-2xl transition-all"><span class="inline-icon" id="icon-target"></span> 今日目標</button>
      <button id="tab-shared" class="flex-1 py-3 text-sm font-semibold flex items-center justify-center gap-2 tab-inactive rounded-2xl transition-all"><span class="inline-icon" id="icon-heart"></span> 共同</button>
      <button id="tab-all" class="flex-1 py-3 text-sm font-semibold tab-inactive rounded-2xl transition-all">全部</button>
    </div>
  </div>

  <div id="habits-container" class="px-4 pb-3 space-y-3.5"></div>
  <div id="add-wrap" class="px-4 pb-28" style="display:none">
    <button id="add-btn" class="add-habit-btn">+ 新增共同習慣</button>
  </div>

  <nav class="bottom-nav">
    <a href="/habits" class="active"><span class="nav-icon" id="nav-habits"></span><span>習慣</span></a>
    <a href="/calendar"><span class="nav-icon" id="nav-calendar"></span><span>月曆</span></a>
    <a href="/australia"><span class="nav-icon" id="nav-australia"></span><span>澳洲</span></a>
  </nav>

  <!-- User Modal -->
  <div id="user-modal" class="modal-backdrop" style="display:none">
    <div class="modal-content">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-bold">個人設定</h2>
        <button onclick="document.getElementById('user-modal').style.display='none'" class="text-2xl text-gray-text cursor-pointer bg-transparent border-none">×</button>
      </div>
      <form id="user-form" class="space-y-4">
        <div><label class="block text-sm font-semibold mb-1.5">你的名稱</label><input type="text" id="uf-name" class="form-input" placeholder="輸入名稱" /></div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="document.getElementById('user-modal').style.display='none'" class="btn-outline flex-1">取消</button>
          <button type="submit" class="btn-gradient flex-1">儲存</button>
        </div>
      </form>
      <hr style="border:none;border-top:1px solid var(--color-gray-mid);margin:20px 0 16px" />
      <button type="button" onclick="document.getElementById('user-modal').style.display='none';window.location.href='/quotes'" class="w-full flex items-center justify-between py-3 px-1 bg-transparent border-none cursor-pointer" style="font-family:'Noto Sans TC',sans-serif">
        <span class="text-base font-bold text-dark">激勵語錄</span>
        <span style="color:var(--color-gray-text);font-size:18px">›</span>
      </button>
      <hr style="border:none;border-top:1px solid var(--color-gray-mid);margin:20px 0 16px" />
      <form id="pw-form" class="space-y-4">
        <h3 class="text-base font-bold">變更密碼</h3>
        <div><label class="block text-sm font-semibold mb-1.5">新密碼</label><input type="password" id="pw-new" class="form-input" placeholder="至少 6 個字元" /></div>
        <div><label class="block text-sm font-semibold mb-1.5">確認新密碼</label><input type="password" id="pw-confirm" class="form-input" placeholder="再輸入一次" /></div>
        <div id="pw-error" class="text-sm text-center" style="color:var(--color-red);display:none"></div>
        <div id="pw-success" class="text-sm text-center" style="color:var(--color-green);display:none"></div>
        <button type="submit" class="btn-outline w-full">更新密碼</button>
      </form>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div id="habit-modal" class="modal-backdrop" style="display:none">
    <div class="modal-content">
      <div class="flex items-center justify-between mb-6">
        <h2 id="modal-title" class="text-xl font-bold">新增習慣</h2>
        <button id="modal-close" class="text-2xl text-gray-text cursor-pointer bg-transparent border-none">×</button>
      </div>
      <form id="habit-form" class="space-y-5">
        <div><label class="block text-sm font-semibold mb-1.5">習慣名稱</label><input type="text" id="hf-name" placeholder="例如：早起運動" class="form-input" required /></div>
        <div><label class="block text-sm font-semibold mb-1.5">類型</label><select id="hf-type" class="form-select"><option value="shared">共同習慣</option><option value="personal">個人習慣</option></select></div>
        <div><label class="block text-sm font-semibold mb-1.5">分類</label><select id="hf-cat" class="form-select"><option value="一般習慣">一般習慣</option><option value="感恩紀錄">感恩紀錄</option><option value="學習">學習</option><option value="運動">運動</option><option value="飲食">飲食</option></select></div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="modal-cancel" class="btn-outline flex-1">取消</button>
          <button type="submit" id="modal-submit" class="btn-gradient flex-1">新增</button>
        </div>
      </form>
    </div>
  </div>

  <div id="delete-modal" class="modal-backdrop" style="display:none">
    <div class="modal-content text-center">
      <p class="text-lg font-bold mb-2">確定刪除？</p>
      <p class="text-gray-text text-sm mb-6">此操作無法復原</p>
      <div class="flex gap-3">
        <button id="del-cancel" class="btn-outline flex-1">取消</button>
        <button id="del-confirm" class="flex-1 py-3 rounded-2xl text-white font-semibold cursor-pointer border-none" style="background:var(--color-red)">刪除</button>
      </div>
    </div>
  </div>

  <script is:inline>
    let currentTab='today',editingId=null,deletingId=null,habitsCache=[];

    const QUOTES=[
      '「每一個小習慣，都是通往更好自己的一步」💪',
      '「一起努力的日子，都是最珍貴的」💕',
      '「堅持不是因為容易，而是因為值得」✨',
      '「今天的你，比昨天更強大」🌟',
      '「兩個人一起堅持，力量加倍」♡',
      '「不必完美，但求進步」🌱',
      '「每天進步 1%，一年後你會驚艷自己」📈',
      '「好習慣是送給未來自己最好的禮物」🎁',
      '「一起變好，是最浪漫的事」🌹',
      '「你的堅持，我都看得見」👀💛',
    ];

    // ===== Auth + Init =====
    // Inject tab icons
    if(ICONS){
      const it=document.getElementById('icon-target');if(it)it.innerHTML=ICONS.target;
      const ih=document.getElementById('icon-heart');if(ih)ih.innerHTML=ICONS.heart;
    }

    async function appInit(){
      if(SB.initFromCache()){
        updateGreeting();
        document.getElementById('auth-guard').style.display='none';
      }
      const ok=await SB.init();
      if(!ok||!SB.myProfile){window.location.href='/';return;}
      updateGreeting();
      if(!SB.partnerProfile){
        const code=await SB.getInviteCode();
        if(code){
          document.getElementById('invite-code').textContent=code;
          document.getElementById('invite-banner').style.display='';
        }
      }
      await Promise.all([reloadHabits(), window._loadBannerCover?.(), loadQuotes()]);
      document.getElementById('auth-guard').style.display='none';
      render();
    }

    function myEmoji(){return SB.myProfile?.emoji||'👩';}
    function bfEmoji(){return SB.partnerProfile?.emoji||'👦';}
    function partnerLabel(){
      const e=SB.partnerProfile?.emoji;
      if(e==='👩')return '女友';
      return '男友';
    }
    function displayName(n){
      if(n==='我')return SB.myProfile?.display_name||'我';
      if(n==='男友'||n==='女友')return SB.partnerProfile?.display_name||partnerLabel();
      return n;
    }
    function updateGreeting(){document.getElementById('user-greeting').textContent=displayName('我');}

    let customQuotes=[];
    async function loadQuotes(){
      try{
        const r=await SB.loadQuotes();
        if(r&&r.image_url){customQuotes=JSON.parse(r.image_url)||[];}
      }catch(e){}
    }

    window.openUserModal=function(){
      document.getElementById('uf-name').value=SB.myProfile?.display_name||'';
      document.getElementById('pw-new').value='';
      document.getElementById('pw-confirm').value='';
      document.getElementById('pw-error').style.display='none';
      document.getElementById('pw-success').style.display='none';
      document.getElementById('user-modal').style.display='flex';
    };
    document.getElementById('user-form').addEventListener('submit',async function(e){
      e.preventDefault();
      const name=document.getElementById('uf-name').value.trim();
      if(name){await SB.updateDisplayName(name);updateGreeting();render();}
      document.getElementById('user-modal').style.display='none';
    });
    document.getElementById('pw-form').addEventListener('submit',async function(e){
      e.preventDefault();
      const pw=document.getElementById('pw-new').value;
      const pw2=document.getElementById('pw-confirm').value;
      const err=document.getElementById('pw-error');
      const ok=document.getElementById('pw-success');
      err.style.display='none';ok.style.display='none';
      if(pw.length<6){err.textContent='密碼至少 6 個字元';err.style.display='';return;}
      if(pw!==pw2){err.textContent='兩次密碼不一致';err.style.display='';return;}
      try{await SB.updatePassword(pw);}
      catch(e){err.textContent=e.message;err.style.display='';return;}
      ok.textContent='密碼已更新 ✓';ok.style.display='';
      document.getElementById('pw-new').value='';
      document.getElementById('pw-confirm').value='';
    });

    async function reloadHabits(){habitsCache=await SB.loadHabits();}
    function getHabits(){return habitsCache;}

    // ===== Cover =====
    (function(){
      const COVER_ID='habits-banner';
      const imgEl=document.getElementById('banner-img'),zoomEl=document.getElementById('banner-zoom');
      let scale=1,posX=0,posY=0,dragging=false,startX=0,startY=0,lx=0,ly=0;
      let saveTimer=null;
      function apply(){imgEl.style.transform='scale('+scale+') translate('+posX+'px,'+posY+'px)';}
      function debounceSave(){
        clearTimeout(saveTimer);
        saveTimer=setTimeout(()=>{
          // Only save URL covers, not base64 (too large)
          const src=imgEl.src;
          if(src&&!src.startsWith('data:')){
            SB.saveCover(COVER_ID,src,Math.round(scale*100),Math.round(posX),Math.round(posY));
          }
        },800);
      }
      zoomEl.addEventListener('input',function(e){e.stopPropagation();scale=parseInt(this.value)/100;apply();debounceSave();});
      imgEl.addEventListener('mousedown',function(e){e.preventDefault();e.stopPropagation();dragging=true;startX=e.clientX;startY=e.clientY;lx=posX;ly=posY;});
      document.addEventListener('mousemove',function(e){if(!dragging)return;posX=lx+(e.clientX-startX)/scale;posY=ly+(e.clientY-startY)/scale;apply();});
      document.addEventListener('mouseup',function(){if(dragging){dragging=false;debounceSave();}});
      imgEl.addEventListener('touchstart',function(e){dragging=true;startX=e.touches[0].clientX;startY=e.touches[0].clientY;lx=posX;ly=posY;},{passive:true});
      document.addEventListener('touchmove',function(e){if(!dragging)return;posX=lx+(e.touches[0].clientX-startX)/scale;posY=ly+(e.touches[0].clientY-startY)/scale;apply();},{passive:true});
      document.addEventListener('touchend',function(){if(dragging){dragging=false;debounceSave();}});
      function setCover(src){
        imgEl.src=src;scale=1;posX=0;posY=0;zoomEl.value=100;apply();
        // Only save URL covers to DB
        if(!src.startsWith('data:')){
          SB.saveCover(COVER_ID,src,100,0,0);
        }
      }
      document.getElementById('banner-file').addEventListener('change',e=>{const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>setCover(ev.target.result);r.readAsDataURL(f);});
      document.getElementById('banner-url-btn').addEventListener('click',()=>{const url=prompt('輸入圖片網址：');if(url)setCover(url);});
      window._loadBannerCover=async function(){
        const c=await SB.loadCover(COVER_ID);
        if(c&&c.image_url){imgEl.src=c.image_url;scale=(c.zoom||100)/100;posX=c.pos_x||0;posY=c.pos_y||0;zoomEl.value=c.zoom||100;apply();}
      };
    })();

    // ===== Render =====
    function render(){
      const habits=getHabits(),c=document.getElementById('habits-container'),aw=document.getElementById('add-wrap');
      if(currentTab==='today'){renderToday(habits,c);aw.style.display='none';}
      else if(currentTab==='shared'){renderShared(habits,c);aw.style.display='block';document.getElementById('add-btn').textContent='+ 新增共同習慣';}
      else{renderAll(habits,c);aw.style.display='none';}
    }

    // ===== TODAY TAB =====
    let todayData=null;

    async function loadTodayData(){
      todayData=await SB.loadTodayRecords();
    }

    async function renderToday(habits,c){
      if(!todayData) await loadTodayData();
      const allQuotes=customQuotes.length?customQuotes:QUOTES;
      const quote=allQuotes[Math.floor(Math.random()*allQuotes.length)];
      const td=todayData;
      const today=td?.today||new Date().toISOString().split('T')[0];
      const d=new Date(today+'T00:00:00');
      const todayLabel=`${d.getMonth()+1}月${d.getDate()}日`;

      let html=`<div class="habit-card text-center" style="margin-bottom:16px;padding:20px 16px">
        <p style="font-size:14px;color:var(--color-gray-text);font-style:italic">${quote}</p>
      </div>`;

      // Show all habits with check-in status for today
      const myId=SB.myId, partnerId=SB.partnerProfile?.id;

      // My section
      html+=`<div style="margin-bottom:20px">
        <div class="flex items-center gap-2 mb-3">
          <span style="font-size:20px">${myEmoji()}</span>
          <h3 style="font-size:16px;font-weight:700">${displayName('我')}的今日目標</h3>
        </div>`;

      habits.forEach(h=>{
        if(h.type==='personal'&&h.owner!=='me')return;
        const done=h.type==='shared'?h.users?.find(u=>u.name==='我')?.done:h.done;
        const myRecords=(td?.records||[]).filter(r=>r.habit_id===h.id&&r.user_id===myId);
        html+=todayCard(h,done,true,myRecords);
      });
      html+='</div>';

      // Partner section
      html+=`<div style="margin-bottom:20px">
        <div class="flex items-center gap-2 mb-3">
          <span style="font-size:20px">${bfEmoji()}</span>
          <h3 style="font-size:16px;font-weight:700">${displayName('男友')}的今日目標</h3>
        </div>`;

      habits.forEach(h=>{
        if(h.type==='personal'&&h.owner!=='bf')return;
        const done=h.type==='shared'?h.users?.find(u=>u.name==='男友')?.done:h.done;
        const bfRecords=(td?.records||[]).filter(r=>r.habit_id===h.id&&r.user_id===partnerId);
        html+=todayCard(h,done,false,bfRecords);
      });
      html+='</div>';

      html+='<div style="height:80px"></div>';
      c.innerHTML=html;
    }

    function todayCard(h,done,isMine,records){
      const checkStyle=done
        ?'width:28px;height:28px;border-radius:50%;background:var(--color-green);color:white;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:bold;cursor:pointer;border:none;flex-shrink:0'
        :'width:28px;height:28px;border-radius:50%;background:transparent;border:2px solid var(--color-gray-mid);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0';

      let recordHtml='';
      if(records&&records.length){
        records.forEach(r=>{
          const content=typeof r.content==='string'?JSON.parse(r.content):r.content;
          if(!content)return;
          let summary='';
          // Smart display per category
          if(h.category==='學習'){
            if(content.topic)summary=`📚 ${content.topic}`;
            else if(content.words?.length)summary=`${content.words.slice(0,3).join('、')}`;
            if(content.source){
              const src=content.source.startsWith('http')?`<a href="${content.source}" target="_blank" style="color:var(--color-bf);text-decoration:underline">${new URL(content.source).hostname}</a>`:content.source;
              summary+=summary?` · ${src}`:src;
            }
          }else if(h.category==='感恩紀錄'){
            if(content.items?.length)summary=`🙏 ${content.items.slice(0,2).join('、')}${content.items.length>2?' ...':''}`;
          }else{
            const parts=[];
            Object.entries(content).forEach(([k,v])=>{
              if(v&&k!=='note'&&!Array.isArray(v))parts.push(`${v}`);
            });
            if(content?.note)parts.push(content.note);
            summary=parts.join(' · ');
          }
          if(summary)recordHtml+=`<div style="font-size:13px;color:var(--color-gray-text);margin-top:4px;margin-left:40px">${summary}</div>`;
        });
      }

      return`<div class="habit-card" style="margin-bottom:10px;padding:14px 16px;cursor:pointer" onclick="goDetail(event,${h.id})">
        <div style="display:flex;align-items:center;gap:12px">
          <button style="${checkStyle}" ${isMine?`onclick="event.stopPropagation();todayToggle(${h.id})"`:''}>${done?'✓':''}</button>
          <span style="font-size:15px;font-weight:600;flex:1;${done?'text-decoration:line-through;opacity:0.5;':''}">${h.name}</span>
          ${h.category?`<span style="font-size:11px;padding:2px 8px;border-radius:99px;background:var(--color-me-light);color:var(--color-gray-text)">${h.category}</span>`:''}
        </div>
        ${recordHtml}
      </div>`;
    }

    window.todayToggle=async function(id){
      await SB.toggleCheckIn(id);
      await Promise.all([reloadHabits(), loadTodayData()]);
      render();
    };

    // ===== SHARED TAB =====
    function renderShared(habits,c){
      const shared=habits.filter(h=>h.type==='shared');
      if(!shared.length){c.innerHTML='<div class="text-center py-12 text-gray-text">還沒有共同習慣</div>';return;}
      c.innerHTML=shared.map(h=>{
        const allDone=h.users.every(u=>u.done);
        return`<div class="habit-card cursor-pointer" onclick="goDetail(event,${h.id})">
          <div style="display:flex;align-items:start;justify-content:space-between;margin-bottom:10px">
            <h3 style="font-size:16px;font-weight:700;font-family:'Noto Sans TC',sans-serif;color:var(--color-dark)">${h.name} ${allDone?'🎉':''}</h3>
            <div style="display:flex;gap:8px;align-items:center">
              <button onclick="event.stopPropagation();openEdit(${h.id})" style="background:none;border:none;cursor:pointer;padding:4px" title="編輯">${ICONS.edit}</button>
              <button onclick="event.stopPropagation();openDelete(${h.id})" style="background:none;border:none;cursor:pointer;padding:4px" title="刪除">${ICONS.trash}</button>
            </div>
          </div>
          ${h.users.map(u=>`
            <div style="display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:10px;margin-bottom:5px;background:${u.name==='我'?'var(--color-me-light)':'var(--color-gray-light)'}">
              <span style="font-size:18px">${u.emoji}</span>
              <span style="font-weight:600;font-size:15px;flex:1">${displayName(u.name)}</span>
              ${u.streak>0?`<span style="font-size:13px;color:var(--color-streak)">🔥 ${u.streak} 天</span>`:''}
            </div>
          `).join('')}
        </div>`;
      }).join('');
    }

    // ===== ALL TAB =====
    function renderAll(habits,c){
      const myShared=habits.filter(h=>h.type==='shared').map(h=>{
        const me=h.users.find(u=>u.name==='我');
        return{id:h.id,name:h.name,streak:me?.streak||0,done:me?.done||false,isShared:true};
      });
      const myPersonal=habits.filter(h=>h.type==='personal'&&h.owner==='me').map(h=>({id:h.id,name:h.name,streak:h.streak,done:h.done,isShared:false}));
      const bfShared=habits.filter(h=>h.type==='shared').map(h=>{
        const bf=h.users.find(u=>u.name==='男友');
        return{id:h.id,name:h.name,streak:bf?.streak||0,done:bf?.done||false,isShared:true};
      });
      const bfPersonal=habits.filter(h=>h.type==='personal'&&h.owner==='bf').map(h=>({id:h.id,name:h.name,streak:h.streak,done:h.done,isShared:false}));
      let html=`<div class="flex items-center justify-between mb-3 mt-2"><h2 class="text-base font-bold flex items-center gap-2"><span class="text-lg">${myEmoji()}</span> ${displayName('我')}的習慣</h2>
        <button onclick="openAddPersonal('me')" class="text-sm font-semibold bg-transparent border-none cursor-pointer" style="color:var(--color-me)">+ 新增</button></div>`;
      [...myShared,...myPersonal].forEach(h=>{html+=flatCard(h,true);});
      html+=`<div class="flex items-center justify-between mb-3 mt-6"><h2 class="text-base font-bold flex items-center gap-2"><span class="text-lg">${bfEmoji()}</span> ${displayName('男友')}的習慣</h2></div>`;
      [...bfShared,...bfPersonal].forEach(h=>{html+=flatCard(h,false);});
      html+='<div style="height:80px"></div>';
      c.innerHTML=html;
    }

    function flatCard(h,isMine){
      return`<div class="habit-card cursor-pointer" style="margin-bottom:12px" onclick="goDetail(event,${h.id})">
        <div style="display:flex;align-items:center;gap:10px">
          <div style="flex:1">
            <h3 style="font-size:15px;font-weight:700;font-family:'Noto Sans TC',sans-serif">${h.name}</h3>
            ${h.streak>0?`<p style="font-size:13px;color:var(--color-streak)">🔥 ${h.streak} 天</p>`:''}
          </div>
          ${isMine?`
            <button onclick="event.stopPropagation();openEdit(${h.id})" style="background:none;border:none;cursor:pointer;padding:4px" title="編輯">${ICONS.edit}</button>
            <button onclick="event.stopPropagation();openDelete(${h.id})" style="background:none;border:none;cursor:pointer;padding:4px" title="刪除">${ICONS.trash}</button>
          `:''}
        </div>
      </div>`;
    }

    window.goDetail=function(e,id){if(e.target.closest('button'))return;window.location.href='/detail?id='+id;};

    // ===== Tabs =====
    function setTab(tab){
      currentTab=tab;
      ['today','shared','all'].forEach(t=>{
        const el=document.getElementById('tab-'+t);
        if(t===tab)el.className='flex-1 py-3 text-sm font-semibold flex items-center justify-center gap-2 tab-active rounded-2xl transition-all';
        else el.className='flex-1 py-3 text-sm font-semibold tab-inactive rounded-2xl transition-all';
      });
      render();
    }
    document.getElementById('tab-today').addEventListener('click',()=>setTab('today'));
    document.getElementById('tab-shared').addEventListener('click',()=>setTab('shared'));
    document.getElementById('tab-all').addEventListener('click',()=>setTab('all'));

    // ===== Modals =====
    const modal=document.getElementById('habit-modal'),delModal=document.getElementById('delete-modal');
    document.getElementById('add-btn').addEventListener('click',()=>{editingId=null;document.getElementById('modal-title').textContent='新增習慣';document.getElementById('modal-submit').textContent='新增';document.getElementById('hf-name').value='';document.getElementById('hf-type').value='shared';document.getElementById('hf-cat').value='一般習慣';modal.style.display='flex';});
    window.openAddPersonal=function(){editingId=null;document.getElementById('modal-title').textContent='新增習慣';document.getElementById('modal-submit').textContent='新增';document.getElementById('hf-name').value='';document.getElementById('hf-type').value='personal';document.getElementById('hf-cat').value='一般習慣';modal.style.display='flex';};
    window.openEdit=function(id){const h=getHabits().find(x=>x.id===id);if(!h)return;editingId=id;document.getElementById('modal-title').textContent='編輯習慣';document.getElementById('modal-submit').textContent='儲存';document.getElementById('hf-name').value=h.name;document.getElementById('hf-type').value=h.type;document.getElementById('hf-cat').value=h.category;modal.style.display='flex';};
    window.openDelete=function(id){deletingId=id;delModal.style.display='flex';};

    document.getElementById('del-confirm').addEventListener('click',async()=>{
      if(deletingId!==null){await SB.deleteHabit(deletingId);await reloadHabits();render();}
      delModal.style.display='none';deletingId=null;
    });

    document.getElementById('habit-form').addEventListener('submit',async function(e){
      e.preventDefault();
      const name=document.getElementById('hf-name').value.trim(),type=document.getElementById('hf-type').value,cat=document.getElementById('hf-cat').value;
      if(!name)return;
      if(editingId!==null){await SB.updateHabit(editingId,name,type,cat);}
      else{await SB.addHabit(name,type,cat);}
      await reloadHabits();modal.style.display='none';editingId=null;render();
    });

    document.getElementById('modal-close').addEventListener('click',()=>{modal.style.display='none';});
    document.getElementById('modal-cancel').addEventListener('click',()=>{modal.style.display='none';});
    document.getElementById('del-cancel').addEventListener('click',()=>{delModal.style.display='none';});

    appInit();
  </script>
</Layout>
