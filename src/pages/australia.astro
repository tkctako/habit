---
import Layout from '../layouts/Layout.astro';
---
<Layout title="澳洲準備">
  <div class="flex items-center justify-between px-5 py-3.5 bg-card border-b border-gray-mid">
    <h1 class="text-lg font-bold text-dark flex items-center gap-2" style="font-family:'Cormorant Garamond','Noto Sans TC',serif;letter-spacing:0.02em"><span id="title-palm"></span> 澳洲準備</h1>
    <div class="flex items-center gap-3">
      <span id="user-greeting" class="text-sm font-semibold text-dark"></span>
      <button onclick="openUserModal()" class="flex items-center justify-center" style="background:none;border:none;cursor:pointer;width:28px;height:28px;color:var(--color-accent)" id="user-icon-btn"></button>
      <button onclick="SB.signOut()" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-mid bg-transparent text-gray-text cursor-pointer" style="font-family:'Noto Sans TC',sans-serif">登出</button>
    </div>
  </div>

  <div class="px-4 pt-5 pb-24">
    <!-- Subtitle -->
    <div class="text-center mb-5">
      <p class="text-sm" style="color:var(--color-gray-text)">一起規劃我們的澳洲冒險之旅</p>
    </div>

    <!-- Progress -->
    <div id="progress-card" class="rounded-2xl p-5 mb-5" style="background:var(--color-me-light);border:1px solid var(--color-gray-mid)">
      <div class="flex items-center justify-between mb-3">
        <span style="font-weight:700;color:var(--color-accent);font-size:15px">整體進度</span>
        <span id="au-pct" style="font-weight:800;font-size:24px;color:var(--color-accent);font-family:'Cormorant Garamond',serif">0%</span>
      </div>
      <div class="w-full h-2.5 rounded-full" style="background:var(--color-warm-dark)">
        <div id="au-bar" class="h-2.5 rounded-full transition-all" style="background:var(--color-me);width:0%"></div>
      </div>
      <p id="au-count" class="text-center text-sm mt-3" style="color:var(--color-bf)">✓ 0 / 0 項目完成</p>
    </div>

    <!-- Add button -->
    <button id="au-add-btn" class="add-habit-btn mb-5">＋ 新增準備事項</button>

    <!-- Category tabs -->
    <div id="au-tabs" class="flex gap-2 mb-5 overflow-x-auto pb-2" style="scrollbar-width:none"></div>

    <!-- Items list -->
    <div id="au-items"></div>

    <!-- Category stats -->
    <div id="au-stats" class="mt-6"></div>

    <div style="height:80px"></div>
  </div>

  <nav class="bottom-nav">
    <a href="/habits"><span class="nav-icon" id="nav-habits"></span><span>習慣</span></a>
    <a href="/calendar"><span class="nav-icon" id="nav-calendar"></span><span>月曆</span></a>
    <a href="/australia" class="active"><span class="nav-icon" id="nav-australia"></span><span>澳洲</span></a>
  </nav>

  <!-- Add/Edit Modal -->
  <div id="au-modal" class="modal-backdrop" style="display:none">
    <div class="modal-content">
      <div class="flex items-center justify-between mb-5">
        <h2 id="au-modal-title" class="text-lg font-bold">新增準備事項</h2>
        <button onclick="document.getElementById('au-modal').style.display='none'" class="text-2xl text-gray-text cursor-pointer bg-transparent border-none">×</button>
      </div>
      <form id="au-form" class="space-y-4">
        <div><label class="block text-sm font-semibold mb-1">標題 *</label><input type="text" id="af-title" class="form-input" placeholder="例如：申請打工度假簽證" required /></div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-sm font-semibold mb-1">分類 *</label><select id="af-cat" class="form-select"><option>行前準備</option><option>工作準備</option><option>住宿安排</option><option>交通規劃</option><option>其他事項</option></select></div>
          <div><label class="block text-sm font-semibold mb-1">優先級</label><select id="af-priority" class="form-select"><option>高優先</option><option>中優先</option><option>低優先</option></select></div>
        </div>
        <div><label class="block text-sm font-semibold mb-1">說明描述</label><textarea id="af-desc" class="form-input" rows="3" placeholder="詳細說明這個準備事項..." style="resize:vertical"></textarea></div>
        <div><label class="block text-sm font-semibold mb-1">參考連結或資訊</label><input type="text" id="af-ref" class="form-input" placeholder="網址、地址、電話或其他參考資訊..." /></div>
        <div><label class="block text-sm font-semibold mb-1">注意事項 / 備註</label><textarea id="af-notes" class="form-input" rows="2" placeholder="重要提醒、費用、所需時間等注意事項..." style="resize:vertical"></textarea></div>
        <div class="flex gap-3 pt-2">
          <button type="submit" id="af-submit" class="btn-gradient flex-1">新增</button>
          <button type="button" onclick="document.getElementById('au-modal').style.display='none'" class="btn-outline flex-1">取消</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Modal -->
  <div id="au-del-modal" class="modal-backdrop" style="display:none">
    <div class="modal-content text-center">
      <p class="text-lg font-bold mb-2">確定刪除？</p>
      <p class="text-gray-text text-sm mb-6">此操作無法復原</p>
      <div class="flex gap-3">
        <button onclick="document.getElementById('au-del-modal').style.display='none'" class="btn-outline flex-1">取消</button>
        <button id="au-del-confirm" class="flex-1 py-3 rounded-2xl text-white font-semibold cursor-pointer border-none" style="background:var(--color-red)">刪除</button>
      </div>
    </div>
  </div>

  <script is:inline>
    let auItems=[],auFilter='全部',editId=null,deleteId=null;

    const CAT_ICONS={'行前準備':ICONS.luggage,'工作準備':ICONS.briefcase,'住宿安排':ICONS.home,'交通規劃':ICONS.plane,'其他事項':ICONS.pin};
    const PRIORITY_COLORS={'高優先':'var(--color-red)','中優先':'var(--color-me)','低優先':'var(--color-green)'};

    const EDIT_SVG=`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
    const DEL_SVG=`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>`;

    // Inject title icon
    if(ICONS){const tp=document.getElementById('title-palm');if(tp)tp.innerHTML=ICONS.palmtree;}

    async function loadItems(){
      auItems=await SB.loadAustralia();
    }

    function render(){
      const total=auItems.length, done=auItems.filter(i=>i.done).length;
      const pct=total?Math.round(done/total*100):0;
      document.getElementById('au-pct').textContent=pct+'%';
      document.getElementById('au-bar').style.width=pct+'%';
      document.getElementById('au-count').textContent=`✓ ${done} / ${total} 項目完成`;

      // Tabs
      const cats=['全部',...Object.keys(CAT_ICONS)];
      document.getElementById('au-tabs').innerHTML=cats.map(c=>{
        const count=c==='全部'?total:auItems.filter(i=>i.category===c).length;
        const doneCount=c==='全部'?done:auItems.filter(i=>i.category===c&&i.done).length;
        const isActive=auFilter===c;
        const bg=isActive?'background:linear-gradient(135deg,var(--color-me),var(--color-accent));color:white;border:none;font-weight:700;':'background:var(--color-card);color:var(--color-gray-text);border:1px solid var(--color-gray-mid);font-weight:600;';
        return`<button onclick="setAuFilter('${c}')" style="${bg}padding:6px 12px;border-radius:99px;font-size:12px;white-space:nowrap;cursor:pointer;flex-shrink:0;font-family:'Noto Sans TC',sans-serif;display:inline-flex;align-items:center;gap:4px">${c==='全部'?'':`<span style="display:inline-flex;align-items:center">${CAT_ICONS[c]}</span>`}<span>${c} ${doneCount}/${count}</span></button>`;
      }).join('');

      // Items
      const PRIORITY_ORDER={'高優先':0,'中優先':1,'低優先':2};
      const sorted=[...(auFilter==='全部'?auItems:auItems.filter(i=>i.category===auFilter))].sort((a,b)=>(PRIORITY_ORDER[a.priority]??9)-(PRIORITY_ORDER[b.priority]??9));
      const filtered=sorted;
      document.getElementById('au-items').innerHTML=filtered.map(item=>{
        const pColor=PRIORITY_COLORS[item.priority]||'var(--color-me)';
        const catIcon=CAT_ICONS[item.category]||'📋';
        return`<div class="habit-card mb-3.5" style="${item.done?'border-left:3px solid var(--color-green);background:var(--color-green-light)':''}">
          <div style="display:flex;align-items:start;gap:12px">
            <button onclick="toggleAuItem(${item.id})" class="check-btn ${item.done?'check-done':'check-none'}" style="margin-top:2px;flex-shrink:0;width:28px;height:28px;font-size:12px">${item.done?'✓':''}</button>
            <div style="flex:1;min-width:0">
              <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                <span style="font-size:15px;font-weight:700;${item.done?'text-decoration:line-through;opacity:0.6':''}">${item.title}</span>
                <span style="font-size:11px;font-weight:600;padding:1px 8px;border-radius:99px;color:white;background:${pColor}">${item.priority}</span>
              </div>
              <div style="margin-top:4px;font-size:12px;color:var(--color-gray-text)">${catIcon} ${item.category}</div>
            </div>
            <div style="display:flex;gap:6px;flex-shrink:0;margin-top:2px">
              <button onclick="openAuEdit(${item.id})" style="background:none;border:none;cursor:pointer;padding:4px">${EDIT_SVG}</button>
              <button onclick="openAuDelete(${item.id})" style="background:none;border:none;cursor:pointer;padding:4px">${DEL_SVG}</button>
            </div>
          </div>
          ${item.description?`<div style="margin:10px 0 0 40px;padding:10px 14px;border-radius:12px;background:var(--color-gray-light);font-size:13px;color:var(--color-dark);line-height:1.6">${item.description}</div>`:''}
          ${item.reference?`<div style="margin:8px 0 0 40px;padding:10px 14px;border-radius:12px;background:var(--color-me-light);font-size:13px"><span style="font-weight:600;color:var(--color-accent);display:inline-flex;align-items:center;gap:4px">${ICONS.link} 參考</span><br/><span style="color:var(--color-bf);word-break:break-all">${item.reference.startsWith('http')?`<a href="${item.reference}" target="_blank" style="color:var(--color-bf);text-decoration:underline">${item.reference}</a>`:item.reference}</span></div>`:''}
          ${item.notes?`<div style="margin:8px 0 0 40px;padding:10px 14px;border-radius:12px;background:var(--color-warm-section);font-size:13px"><span style="font-weight:600;color:var(--color-bf);display:inline-flex;align-items:center;gap:4px">${ICONS.lightbulb} 備註</span><br/><span style="color:var(--color-dark)">${item.notes}</span></div>`:''}
        </div>`;
      }).join('')||'<p class="text-center text-gray-text py-8">還沒有準備事項</p>';

      // Stats
      const catList=Object.keys(CAT_ICONS);
      document.getElementById('au-stats').innerHTML=`
        <div class="habit-card">
          <h3 style="font-size:15px;font-weight:700;margin-bottom:14px;font-family:'Cormorant Garamond',serif;letter-spacing:0.02em">${ICONS.chart} 分類統計</h3>
          <div class="grid grid-cols-2 gap-3">
            ${catList.map(c=>{
              const items=auItems.filter(i=>i.category===c);
              const d=items.filter(i=>i.done).length;
              const t=items.length;
              const p=t?Math.round(d/t*100):0;
              return`<div class="rounded-xl p-3" style="background:var(--color-gray-light);border:1px solid var(--color-gray-mid)">
                <p style="font-size:13px;font-weight:700;margin-bottom:4px">${CAT_ICONS[c]} ${c}</p>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
                  <span style="font-size:12px;color:var(--color-gray-text)">${d}/${t}</span>
                  <span style="font-size:14px;font-weight:700;color:var(--color-accent);font-family:'Cormorant Garamond',serif">${p}%</span>
                </div>
                <div class="w-full h-1.5 rounded-full" style="background:var(--color-warm-dark)"><div class="h-1.5 rounded-full" style="background:var(--color-me);width:${p}%"></div></div>
              </div>`;
            }).join('')}
          </div>
        </div>`;
    }

    window.setAuFilter=function(f){auFilter=f;render();};

    window.toggleAuItem=async function(id){
      await SB.toggleAustralia(id);
      await loadItems();render();
    };

    // Add/Edit
    document.getElementById('au-add-btn').addEventListener('click',()=>{
      editId=null;
      document.getElementById('au-modal-title').textContent='新增準備事項';
      document.getElementById('af-submit').textContent='新增';
      document.getElementById('af-title').value='';
      document.getElementById('af-cat').value='行前準備';
      document.getElementById('af-priority').value='中優先';
      document.getElementById('af-desc').value='';
      document.getElementById('af-ref').value='';
      document.getElementById('af-notes').value='';
      document.getElementById('au-modal').style.display='flex';
    });

    window.openAuEdit=function(id){
      const item=auItems.find(i=>i.id===id);if(!item)return;
      editId=id;
      document.getElementById('au-modal-title').textContent='編輯準備事項';
      document.getElementById('af-submit').textContent='儲存';
      document.getElementById('af-title').value=item.title;
      document.getElementById('af-cat').value=item.category;
      document.getElementById('af-priority').value=item.priority;
      document.getElementById('af-desc').value=item.description||'';
      document.getElementById('af-ref').value=item.reference||'';
      document.getElementById('af-notes').value=item.notes||'';
      document.getElementById('au-modal').style.display='flex';
    };

    document.getElementById('au-form').addEventListener('submit',async function(e){
      e.preventDefault();
      const data={
        title:document.getElementById('af-title').value.trim(),
        category:document.getElementById('af-cat').value,
        priority:document.getElementById('af-priority').value,
        description:document.getElementById('af-desc').value.trim(),
        reference:document.getElementById('af-ref').value.trim(),
        notes:document.getElementById('af-notes').value.trim()
      };
      if(!data.title)return;
      if(editId!==null){await SB.updateAustralia({id:editId,...data});}
      else{await SB.addAustralia(data);}
      await loadItems();
      document.getElementById('au-modal').style.display='none';
      editId=null;render();
    });

    // Delete
    window.openAuDelete=function(id){deleteId=id;document.getElementById('au-del-modal').style.display='flex';};
    document.getElementById('au-del-confirm').addEventListener('click',async()=>{
      if(deleteId!==null){await SB.deleteAustralia(deleteId);await loadItems();render();}
      document.getElementById('au-del-modal').style.display='none';deleteId=null;
    });

    async function appInit(){
      if(SB.initFromCache())document.getElementById('auth-guard')&&(document.getElementById('auth-guard').style.display='none');
      const ok=await SB.init();
      if(!ok||!SB.myProfile){window.location.href='/';return;}
      await loadItems();
      const ag=document.getElementById('auth-guard');if(ag)ag.style.display='none';
      render();
    }
    appInit();
  </script>
</Layout>
