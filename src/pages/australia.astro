---
import Layout from '../layouts/Layout.astro';
---
<Layout title="澳洲準備">
  <div class="flex items-center justify-between px-5 py-3.5 bg-card border-b border-gray-mid">
    <h1 class="text-lg font-bold text-dark">習慣追蹤</h1>
    <button onclick="SB.signOut()" style="background:none;border:none;cursor:pointer;font-size:18px;color:var(--color-gray-text)">⇥</button>
  </div>

  <div class="px-4 pt-6 pb-24">
    <div class="text-center mb-5">
      <h2 style="font-size:22px;font-weight:800">🇦🇺 澳洲打工度假準備</h2>
      <p class="text-gray-text text-sm mt-1">一起規劃我們的澳洲冒險之旅</p>
    </div>

    <!-- Cover -->
    <div id="au-cover" class="rounded-2xl mb-5 text-center" style="background:linear-gradient(135deg,#f8e8f0,#fce4ec);min-height:120px;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative">
      <img id="au-cover-img" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;display:none" />
      <label class="cursor-pointer" style="color:var(--color-accent);font-size:14px;z-index:2">
        <span id="au-cover-text">📷 添加封面圖片</span>
        <input type="file" accept="image/*" id="au-cover-file" class="hidden" />
      </label>
    </div>

    <!-- Progress -->
    <div id="progress-card" class="rounded-2xl p-5 mb-5" style="background:linear-gradient(135deg,#fff9e6,#fff3cd);border:1px solid #f0e0a0">
      <div class="flex items-center justify-between mb-3">
        <span style="font-weight:700;color:#e67e22;font-size:15px">整體進度</span>
        <span id="au-pct" style="font-weight:800;font-size:24px;color:#e67e22">0%</span>
      </div>
      <div class="w-full h-2.5 rounded-full" style="background:#f0e0a0">
        <div id="au-bar" class="h-2.5 rounded-full transition-all" style="background:#e67e22;width:0%"></div>
      </div>
      <p id="au-count" class="text-center text-sm mt-3" style="color:#b8860b">✓ 0 / 0 項目完成</p>
    </div>

    <!-- Add button -->
    <button id="au-add-btn" class="w-full py-3.5 rounded-2xl text-white font-bold text-base cursor-pointer border-none mb-5" style="background:linear-gradient(135deg,#f39c12,#e67e22)">＋ 新增準備事項</button>

    <!-- Category tabs -->
    <div id="au-tabs" class="flex gap-2 mb-5 overflow-x-auto pb-2" style="scrollbar-width:none"></div>

    <!-- Items list -->
    <div id="au-items"></div>

    <!-- Category stats -->
    <div id="au-stats" class="mt-6"></div>

    <div style="height:80px"></div>
  </div>

  <nav class="bottom-nav">
    <a href="/habits"><span class="text-lg">☰</span><span>習慣</span></a>
    <a href="/calendar"><span class="text-lg">📅</span><span>月曆</span></a>
    <a href="/australia" class="active"><span class="text-lg">🌴</span><span>澳洲</span></a>
  </nav>

  <!-- Add/Edit Modal -->
  <div id="au-modal" class="modal-backdrop" style="display:none">
    <div class="modal-content">
      <div class="flex items-center justify-between mb-5">
        <h2 id="au-modal-title" class="text-lg font-bold">新增準備事項</h2>
        <button onclick="document.getElementById('au-modal').style.display='none'" class="text-2xl text-gray-text cursor-pointer bg-transparent border-none">×</button>
      </div>
      <form id="au-form" class="space-y-4">
        <div><label class="block text-sm font-semibold mb-1">標題 *</label><input type="text" id="af-title" class="form-input" placeholder="例如：申請打工度假簽證" required /></div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-sm font-semibold mb-1">分類 *</label><select id="af-cat" class="form-select"><option>簽證文件</option><option>行前準備</option><option>工作準備</option><option>住宿安排</option><option>交通規劃</option><option>其他事項</option></select></div>
          <div><label class="block text-sm font-semibold mb-1">優先級</label><select id="af-priority" class="form-select"><option>高優先</option><option>中優先</option><option>低優先</option></select></div>
        </div>
        <div><label class="block text-sm font-semibold mb-1">說明描述</label><textarea id="af-desc" class="form-input" rows="3" placeholder="詳細說明這個準備事項..." style="resize:vertical"></textarea></div>
        <div><label class="block text-sm font-semibold mb-1">參考連結或資訊</label><input type="text" id="af-ref" class="form-input" placeholder="網址、地址、電話或其他參考資訊..." /></div>
        <div><label class="block text-sm font-semibold mb-1">注意事項</label><input type="text" id="af-notes" class="form-input" placeholder="需要注意的事項..." /></div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="document.getElementById('au-modal').style.display='none'" class="btn-outline flex-1">取消</button>
          <button type="submit" id="af-submit" class="btn-gradient flex-1">新增</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Modal -->
  <div id="au-del-modal" class="modal-backdrop" style="display:none">
    <div class="modal-content text-center">
      <p class="text-lg font-bold mb-2">確定刪除？</p>
      <p class="text-gray-text text-sm mb-6">此操作無法復原</p>
      <div class="flex gap-3">
        <button onclick="document.getElementById('au-del-modal').style.display='none'" class="btn-outline flex-1">取消</button>
        <button id="au-del-confirm" class="flex-1 py-3 rounded-2xl text-white font-semibold cursor-pointer border-none" style="background:var(--color-red)">刪除</button>
      </div>
    </div>
  </div>

  <script is:inline>
    let auItems=[],auFilter='全部',editId=null,deleteId=null;

    const CAT_ICONS={'簽證文件':'📋','行前準備':'🌐','工作準備':'🏢','住宿安排':'🏠','交通規劃':'✈️','其他事項':'•••'};
    const PRIORITY_COLORS={'高優先':'#e74c3c','中優先':'#f39c12','低優先':'#27ae60'};

    // Cover
    document.getElementById('au-cover-file').addEventListener('change',e=>{
      const f=e.target.files[0];if(!f)return;
      const r=new FileReader();
      r.onload=ev=>{
        const img=document.getElementById('au-cover-img');
        img.src=ev.target.result;img.style.display='block';
        document.getElementById('au-cover-text').style.display='none';
      };
      r.readAsDataURL(f);
    });

    async function loadItems(){
      auItems=await SB.loadAustralia();
    }

    function render(){
      const total=auItems.length, done=auItems.filter(i=>i.done).length;
      const pct=total?Math.round(done/total*100):0;
      document.getElementById('au-pct').textContent=pct+'%';
      document.getElementById('au-bar').style.width=pct+'%';
      document.getElementById('au-count').textContent=`✓ ${done} / ${total} 項目完成`;

      // Tabs
      const cats=['全部',...Object.keys(CAT_ICONS)];
      document.getElementById('au-tabs').innerHTML=cats.map(c=>{
        const count=c==='全部'?total:auItems.filter(i=>i.category===c).length;
        const doneCount=c==='全部'?done:auItems.filter(i=>i.category===c&&i.done).length;
        const isActive=auFilter===c;
        const style=isActive
          ?'background:#e67e22;color:white;border:none;font-weight:700;'
          :'background:var(--color-gray-light);color:var(--color-gray-text);border:1px solid var(--color-gray-mid);font-weight:600;';
        const icon=c==='全部'?'':CAT_ICONS[c]+' ';
        return`<button onclick="setAuFilter('${c}')" style="${style}padding:6px 14px;border-radius:99px;font-size:13px;white-space:nowrap;cursor:pointer;flex-shrink:0">${icon}${c} ${doneCount}/${count}</button>`;
      }).join('');

      // Items
      const filtered=auFilter==='全部'?auItems:auItems.filter(i=>i.category===auFilter);
      document.getElementById('au-items').innerHTML=filtered.map(item=>{
        const pColor=PRIORITY_COLORS[item.priority]||'#f39c12';
        const catIcon=CAT_ICONS[item.category]||'📋';
        const borderColor=item.done?'#27ae60':'var(--color-gray-mid)';
        const bgColor=item.done?'#f0faf0':'var(--color-card)';
        return`<div class="rounded-2xl p-4 mb-4 shadow-sm" style="border:1px solid ${borderColor};background:${bgColor}">
          <div style="display:flex;align-items:start;gap:12px;margin-bottom:10px">
            <div style="width:40px;height:40px;border-radius:12px;background:#fff3cd;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">${catIcon}</div>
            <div style="flex:1">
              <span style="font-size:15px;font-weight:700">${item.title}</span>
              ${item.done?' ✅':''}
            </div>
            <button onclick="openAuEdit(${item.id})" style="background:none;border:none;cursor:pointer;font-size:16px;color:#3498db">✏️</button>
            <button onclick="openAuDelete(${item.id})" style="background:none;border:none;cursor:pointer;font-size:16px;color:#e74c3c">🗑️</button>
          </div>
          <div style="margin-left:52px">
            <span style="font-size:12px;font-weight:600;padding:2px 10px;border-radius:99px;color:white;background:${pColor}">${item.priority}</span>
          </div>
          ${item.description?`<div style="margin:12px 0 0 52px;padding:10px 14px;border-radius:10px;background:var(--color-gray-light);font-size:14px;color:var(--color-dark)">${item.description}</div>`:''}
          ${item.reference?`<div style="margin:10px 0 0 52px;padding:10px 14px;border-radius:10px;background:#e8f4fd;font-size:13px"><span style="font-weight:600;color:#e74c3c">📌 參考資訊</span><br/><span style="color:#2980b9;word-break:break-all">${item.reference.startsWith('http')?`<a href="${item.reference}" target="_blank" style="color:#2980b9">${item.reference}</a>`:item.reference}</span></div>`:''}
          ${item.notes?`<div style="margin:10px 0 0 52px;padding:10px 14px;border-radius:10px;background:#fff9e6;font-size:13px"><span style="font-weight:600;color:#b8860b">💡 注意事項</span><br/>${item.notes}</div>`:''}
          <div style="margin-top:12px;margin-left:52px">
            <button onclick="toggleAuItem(${item.id})" style="width:100%;padding:10px;border-radius:12px;font-size:14px;font-weight:600;cursor:pointer;border:none;${item.done?'background:#27ae60;color:white':'background:var(--color-gray-light);color:var(--color-gray-text)'}">${item.done?'☑️ 已完成':'☐ 標記為完成'}</button>
          </div>
        </div>`;
      }).join('')||'<p class="text-center text-gray-text py-8">還沒有準備事項</p>';

      // Stats
      const catList=Object.keys(CAT_ICONS);
      document.getElementById('au-stats').innerHTML=`
        <div class="rounded-2xl p-5 shadow-sm" style="border:1px solid var(--color-gray-mid);background:var(--color-card)">
          <h3 style="font-size:16px;font-weight:700;margin-bottom:14px">📊 分類統計</h3>
          <div class="grid grid-cols-2 gap-3">
            ${catList.map(c=>{
              const items=auItems.filter(i=>i.category===c);
              const d=items.filter(i=>i.done).length;
              const t=items.length;
              const p=t?Math.round(d/t*100):0;
              return`<div class="rounded-xl p-3.5" style="background:var(--color-gray-light);border:1px solid var(--color-gray-mid)">
                <p style="font-size:14px;font-weight:700;margin-bottom:4px">${CAT_ICONS[c]} ${c}</p>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
                  <span style="font-size:13px;color:var(--color-gray-text)">${d}/${t}</span>
                  <span style="font-size:14px;font-weight:700;color:#e67e22">${p}%</span>
                </div>
                <div class="w-full h-2 rounded-full" style="background:#f0e0a0"><div class="h-2 rounded-full" style="background:#e67e22;width:${p}%"></div></div>
              </div>`;
            }).join('')}
          </div>
        </div>`;
    }

    window.setAuFilter=function(f){auFilter=f;render();};

    window.toggleAuItem=async function(id){
      await SB.toggleAustralia(id);
      await loadItems();render();
    };

    // Add/Edit
    document.getElementById('au-add-btn').addEventListener('click',()=>{
      editId=null;
      document.getElementById('au-modal-title').textContent='新增準備事項';
      document.getElementById('af-submit').textContent='新增';
      document.getElementById('af-title').value='';
      document.getElementById('af-cat').value='行前準備';
      document.getElementById('af-priority').value='中優先';
      document.getElementById('af-desc').value='';
      document.getElementById('af-ref').value='';
      document.getElementById('af-notes').value='';
      document.getElementById('au-modal').style.display='flex';
    });

    window.openAuEdit=function(id){
      const item=auItems.find(i=>i.id===id);if(!item)return;
      editId=id;
      document.getElementById('au-modal-title').textContent='編輯準備事項';
      document.getElementById('af-submit').textContent='儲存';
      document.getElementById('af-title').value=item.title;
      document.getElementById('af-cat').value=item.category;
      document.getElementById('af-priority').value=item.priority;
      document.getElementById('af-desc').value=item.description||'';
      document.getElementById('af-ref').value=item.reference||'';
      document.getElementById('af-notes').value=item.notes||'';
      document.getElementById('au-modal').style.display='flex';
    };

    document.getElementById('au-form').addEventListener('submit',async function(e){
      e.preventDefault();
      const data={
        title:document.getElementById('af-title').value.trim(),
        category:document.getElementById('af-cat').value,
        priority:document.getElementById('af-priority').value,
        description:document.getElementById('af-desc').value.trim(),
        reference:document.getElementById('af-ref').value.trim(),
        notes:document.getElementById('af-notes').value.trim()
      };
      if(!data.title)return;
      if(editId!==null){await SB.updateAustralia({id:editId,...data});}
      else{await SB.addAustralia(data);}
      await loadItems();
      document.getElementById('au-modal').style.display='none';
      editId=null;render();
    });

    // Delete
    window.openAuDelete=function(id){deleteId=id;document.getElementById('au-del-modal').style.display='flex';};
    document.getElementById('au-del-confirm').addEventListener('click',async()=>{
      if(deleteId!==null){await SB.deleteAustralia(deleteId);await loadItems();render();}
      document.getElementById('au-del-modal').style.display='none';deleteId=null;
    });

    async function appInit(){
      if(SB.initFromCache())document.getElementById('auth-guard').style.display='none';
      const ok=await SB.init();
      if(!ok||!SB.myProfile){window.location.href='/';return;}
      await loadItems();
      document.getElementById('auth-guard').style.display='none';
      render();
    }
    appInit();
  </script>
</Layout>
