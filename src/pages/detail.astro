---
import Layout from '../layouts/Layout.astro';
---
<Layout title="習慣詳情">
  <div class="app-header flex items-center justify-between px-5 py-3.5 bg-card border-b border-gray-mid">
    <h1 class="text-lg font-bold text-dark">習慣追蹤</h1>
    <button onclick="SB.signOut()" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-mid bg-transparent text-gray-text cursor-pointer" style="font-family:'Noto Sans TC',sans-serif">登出</button>
  </div>

  <div class="px-4 pt-4 pb-24">
    <div class="flex items-center gap-3 mb-5">
      <a href="/habits" class="text-2xl text-dark no-underline">‹</a>
      <h2 id="habit-title" class="text-xl font-bold text-dark"></h2>
    </div>

    <button id="add-record-btn" class="btn-gradient mb-4 flex items-center justify-center gap-2">+ <span id="add-record-text">新增記錄</span></button>
    <div class="flex items-center justify-between mb-3">
      <h3 id="records-title" class="text-sm font-bold text-dark" style="font-family:'Noto Sans TC',sans-serif"></h3>
      <div class="flex items-center gap-2">
        <button id="batch-toggle" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-mid bg-transparent cursor-pointer" style="color:var(--color-gray-text);font-family:'Noto Sans TC',sans-serif;display:none" onclick="toggleBatchMode()">批次選取</button>
        <button id="batch-all" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-mid bg-transparent cursor-pointer" style="color:var(--color-accent);font-family:'Noto Sans TC',sans-serif;display:none" onclick="batchSelectAll()">全選</button>
        <button id="batch-delete-btn" class="text-xs font-semibold px-3 py-1.5 rounded-full border-none cursor-pointer" style="background:var(--color-red);color:white;font-family:'Noto Sans TC',sans-serif;display:none" onclick="batchDelete()">刪除選取 (0)</button>
        <button id="batch-cancel" class="text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-mid bg-transparent cursor-pointer" style="color:var(--color-gray-text);font-family:'Noto Sans TC',sans-serif;display:none" onclick="toggleBatchMode()">取消</button>
      </div>
    </div>
    <div id="records-container" class="space-y-3"></div>
  </div>

  <nav class="bottom-nav">
    <a href="/habits"><span class="nav-icon" id="nav-habits"></span><span>習慣</span></a>
    <a href="/calendar"><span class="nav-icon" id="nav-calendar"></span><span>月曆</span></a>
    <a href="/australia"><span class="nav-icon" id="nav-australia"></span><span>澳洲</span></a>
  </nav>

  <div id="record-modal" class="modal-backdrop" style="display:none">
    <div class="modal-content" style="max-height:85vh;overflow-y:auto">
      <div class="flex items-center justify-between mb-5">
        <h2 id="rm-title" class="text-lg font-bold">新增記錄</h2>
        <button onclick="closeRM()" class="text-2xl text-gray-text bg-transparent border-none cursor-pointer">×</button>
      </div>
      <form id="record-form" class="space-y-4">
        <div id="date-single"><label class="block text-sm font-semibold mb-1">日期</label><input type="date" id="rf-date" class="form-input" /></div>
        <div id="date-range" style="display:none"><label class="block text-sm font-semibold mb-1">日期範圍</label><div class="flex items-center gap-2"><input type="date" id="rf-date-start" class="form-input flex-1" /><span class="text-gray-text font-semibold">～</span><input type="date" id="rf-date-end" class="form-input flex-1" /></div><p id="date-range-count" class="text-xs mt-1" style="color:var(--color-green)"></p></div>
        <div style="margin-top:4px"><label class="text-xs cursor-pointer flex items-center gap-1" style="color:var(--color-accent)"><input type="checkbox" id="rf-multi" style="accent-color:var(--color-me)" /> 一次新增多天</label></div>
        <div id="record-fields"></div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="btn-gradient flex-1">儲存</button>
          <button type="button" onclick="closeRM()" class="btn-outline flex-1">取消</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    const habitId=parseInt(new URLSearchParams(window.location.search).get('id'));
    let editRecordId=null,recordsCache=[],habit=null;

    async function appInit(){
      if(SB.initFromCache()){
        document.getElementById('auth-guard').style.display='none';
      }
      const ok=await SB.init();
      if(!ok||!SB.myProfile){window.location.href='/';return;}
      const habits=await SB.loadHabits();
      habit=habits.find(h=>h.id===habitId);
      if(!habit){document.getElementById('habit-title').textContent='找不到';return;}
      document.getElementById('habit-title').textContent=habit.name;
      const tpl=getTpl(habit.category);
      const labels={reading:['新增閱讀記錄','閱讀記錄'],learning:['新增語言學習記錄','語言學習記錄'],exercise:['新增運動記錄','運動記錄'],gratitude:['新增感恩紀錄','感恩紀錄'],general:['新增記錄','記錄']};
      document.getElementById('add-record-text').textContent=labels[tpl][0];
      document.getElementById('records-title').textContent=labels[tpl][1];
      await reloadRecords();
      document.getElementById('auth-guard').style.display='none';
      renderRecords();
    }

    function myEmoji(){return SB.myProfile?.emoji||'👩';}
    function bfEmoji(){return SB.partnerProfile?.emoji||'👦';}
    function partnerLabel(){return SB.partnerProfile?.emoji==='👩'?'女友':'男友';}
    function displayName(n){
      if(n==='我')return SB.myProfile?.display_name||'我';
      if(n==='男友'||n==='女友')return SB.partnerProfile?.display_name||partnerLabel();
      return n;
    }

    function getTpl(cat){
      if(cat==='語言學習')return'learning';
      if(cat==='閱讀')return'reading';
      if(cat==='運動')return'exercise';
      if(cat==='感恩紀錄')return'gratitude';
      if(cat==='飲食')return'general';
      return'general';
    }

    let checkInsCache=[];
    async function reloadRecords(){
      const result=await SB.loadRecords(habitId);
      const records=result.records||[];
      checkInsCache=result.checkIns||[];
      recordsCache=records.map(r=>{
        const isMe=r.user_id===SB.myId;
        const content=typeof r.content==='string'?JSON.parse(r.content):r.content||{};
        return{id:r.id,date:r.date,user_id:r.user_id,userName:isMe?displayName('我'):displayName('男友'),userEmoji:isMe?myEmoji():bfEmoji(),isMe,...content};
      });
    }
    function isCheckedIn(date,userId){
      return checkInsCache.some(c=>c.habit_id===habitId&&c.user_id===userId&&c.date===date&&c.done);
    }

    function renderRecords(){
      const records=recordsCache,tpl=getTpl(habit.category);
      const c=document.getElementById('records-container');
      const myRecs=records.filter(r=>r.isMe);
      document.getElementById('batch-toggle').style.display=(!batchMode&&myRecs.length>1)?'':'none';
      if(!records.length){c.innerHTML='<p class="text-center text-gray-text py-8">還沒有記錄</p>';return;}
      c.innerHTML=records.map(r=>{
        let body='';
        const dateDisplay=SB.formatDate(r.date);
        if(tpl==='reading'){
          // Support both old single quote and new quotes array
          const quotes=r.quotes||( r.quote?[r.quote]:[]);
          body=`${r.book?`<div class="flex items-center gap-2 mb-2"><span style="color:var(--color-me)">📖</span><span class="font-bold text-sm">${r.book}</span></div>`:''}
            ${quotes.length?`<div class="rounded-lg p-3 mb-2" style="background:var(--color-me-light);border-left:3px solid var(--color-me)"><p class="text-xs font-semibold mb-1" style="color:var(--color-accent)">✨ 金句</p>${quotes.map((q,i)=>`<p class="text-sm mb-0.5"><span style="color:var(--color-me);font-weight:600">${i+1}.</span>&nbsp;&nbsp;"${q}"</p>`).join('')}</div>`:''}
            ${r.note?`<div class="rounded-lg p-3" style="background:var(--color-gray-light);border-left:3px solid var(--color-bf)"><p class="text-xs font-semibold mb-0.5" style="color:var(--color-bf)">💬 閱讀心得</p><p class="text-sm">${r.note}</p></div>`:''}`;
        }else if(tpl==='learning'){
          const srcHtml=r.source?(r.source.startsWith('http')?`<a href="${r.source}" target="_blank" style="color:var(--color-bf);text-decoration:underline;word-break:break-all">${r.source}</a>`:r.source):'';
          body=`${r.topic?`<div class="rounded-lg p-3 mb-2" style="background:var(--color-me-light);border-left:3px solid var(--color-me)"><p class="text-xs font-semibold mb-0.5" style="color:var(--color-accent)">📚 學習主題</p><p class="text-sm font-bold">${r.topic}</p></div>`:''}
            ${srcHtml?`<div class="rounded-lg p-3 mb-2" style="background:var(--color-warm-section);border-left:3px solid var(--color-bf)"><p class="text-xs font-semibold mb-0.5" style="color:var(--color-bf)">${ICONS.link} 資料來源</p><p class="text-sm">${srcHtml}</p></div>`:''}
            ${r.words?.length?`<div class="rounded-lg p-3 mb-2" style="background:var(--color-green-light);border-left:3px solid var(--color-green)"><p class="text-xs font-semibold mb-1" style="color:var(--color-green)">習得例句或單字</p>${r.words.map((w,i)=>`<p class="text-sm mb-0.5"><span style="color:var(--color-me);font-weight:600">${i+1}.</span>&nbsp;&nbsp;${w}</p>`).join('')}</div>`:''}
            ${r.note?`<div class="rounded-lg p-3" style="background:var(--color-gray-light);border-left:3px solid var(--color-gray-mid)"><p class="text-xs font-semibold mb-0.5">學習筆記</p><p class="text-sm">${r.note}</p></div>`:''}`;
        }else if(tpl==='exercise'){
          body=`<div class="rounded-lg p-3 mb-2" style="background:#f0ebe4;border-left:3px solid var(--color-red)"><p class="text-sm"><b>類型：</b>${r.type||'-'}</p><p class="text-sm"><b>時長：</b>${r.duration||'-'}</p></div>
            ${r.note?`<div class="rounded-lg p-3" style="background:var(--color-gray-light);border-left:3px solid var(--color-gray-mid)"><p class="text-sm">${r.note}</p></div>`:''}`;
        }else if(tpl==='gratitude'){
          body=`${r.items?.length?`<div class="rounded-lg p-3 mb-2" style="background:var(--color-me-light);border-left:3px solid var(--color-me)"><p class="text-xs font-semibold mb-1" style="color:var(--color-accent)">🙏 感恩的事</p>${r.items.map((item,idx)=>`<p class="text-sm mb-0.5"><span style="color:var(--color-me);font-weight:600">${idx+1}.</span>&nbsp;&nbsp;${item}</p>`).join('')}</div>`:''}
            ${r.note?`<div class="rounded-lg p-3" style="background:var(--color-gray-light);border-left:3px solid var(--color-gray-mid)"><p class="text-xs font-semibold mb-0.5">備註</p><p class="text-sm">${r.note}</p></div>`:''}`;
        }else{
          body=r.note?`<div class="rounded-lg p-3" style="background:var(--color-gray-light);border-left:3px solid var(--color-gray-mid)"><p class="text-sm">${r.note}</p></div>`:'';
        }
        const userBadge=habit.type==='shared'?`<span style="font-size:13px;margin-left:8px">${r.userEmoji} ${r.userName}</span>`:'';
        const batchCb=batchMode&&r.isMe?`<input type="checkbox" id="batch-cb-${r.id}" ${batchSelected.has(r.id)?'checked':''} onclick="event.stopPropagation();toggleBatchItem(${r.id})" style="accent-color:var(--color-me);width:18px;height:18px;cursor:pointer;flex-shrink:0" />`:'';
        const editBtns=batchMode?'':(r.isMe?`<button onclick="openEditR(${r.id})" style="background:none;border:none;cursor:pointer;padding:4px" title="編輯">${ICONS.edit}</button><button onclick="deleteR(${r.id})" style="background:none;border:none;cursor:pointer;padding:4px" title="刪除">${ICONS.trash}</button>`:'');
        const checked=isCheckedIn(r.date,r.user_id);
        const checkBtn=r.isMe?`<button class="check-btn ${checked?'check-done':'check-none'}" onclick="toggleRecordCheck('${r.date}')" style="flex-shrink:0">${checked?'✓':'✕'}</button>`:`<span class="check-btn ${checked?'check-done':'check-none'}" style="flex-shrink:0;opacity:0.4;cursor:default">${checked?'✓':'✕'}</span>`;
        return`<div class="habit-card" ${batchMode&&r.isMe?`onclick="toggleBatchItem(${r.id})" style="cursor:pointer"`:''}><div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">${batchCb}${checkBtn}<span style="font-size:14px;color:var(--color-gray-text);flex:1">${ICONS.calendarDay} ${dateDisplay}${userBadge}</span><div style="display:flex;gap:8px">${editBtns}</div></div>${body}</div>`;
      }).join('');
    }

    // ===== Form fields =====
    function getFields(tpl,r){
      r=r||{};
      if(tpl==='gratitude'){
        const items=r.items||[];
        const rowCount=Math.max(items.length+3,5);
        let lines='';
        for(let i=0;i<rowCount;i++){
          lines+=`<div class="flex items-center gap-2 mb-1 gratitude-row"><span class="text-sm font-bold" style="color:var(--color-me);min-width:24px">${i+1}.</span><input type="text" data-gratitude-input value="${items[i]||''}" class="form-input flex-1" style="padding:8px 12px" placeholder="感恩的事..." /></div>`;
        }
        return`<div><label class="block text-sm font-semibold mb-1">🙏 感恩的事</label><div id="gratitude-list" class="rounded-xl border p-3 max-h-[300px] overflow-y-auto" style="border-color:var(--color-me)">${lines}</div><div class="flex items-center justify-between mt-1"><p id="item-count" class="text-xs" style="color:var(--color-green)">已輸入 ${items.filter(x=>x).length} 個</p><button type="button" onclick="addGratitudeRow()" class="text-xs font-semibold bg-transparent border-none cursor-pointer" style="color:var(--color-me)">+ 新增一行</button></div></div>
        <div><label class="block text-sm font-semibold mb-1">備註</label><textarea id="rf-note" rows="2" class="form-input" style="resize:none">${r.note||''}</textarea></div>`;
      }
      if(tpl==='learning'){
        const words=r.words||[];
        const rowCount=Math.max(words.length+3,10);
        let lines='';
        for(let i=0;i<rowCount;i++)lines+=`<div class="flex items-center gap-2 mb-1 learning-row"><span class="text-sm font-bold" style="color:var(--color-me);min-width:28px">${i+1}.</span><input type="text" data-word-input value="${words[i]||''}" class="form-input flex-1" style="padding:8px 12px" /></div>`;
        return`<div><label class="block text-sm font-semibold mb-1">學習主題</label><input id="rf-topic" value="${r.topic||''}" class="form-input" placeholder="今天學了什麼？" /></div>
        <div><label class="block text-sm font-semibold mb-1">資料來源</label><input id="rf-source" value="${r.source||''}" class="form-input" placeholder="網址、書名或其他來源..." /></div>
        <div><label class="block text-sm font-semibold mb-1">習得例句或單字</label><div id="word-list" class="rounded-xl border p-3 max-h-[250px] overflow-y-auto" style="border-color:var(--color-me)">${lines}</div><div class="flex items-center justify-between mt-1"><p id="word-count" class="text-xs" style="color:var(--color-green)">已輸入 ${words.filter(x=>x).length} 個</p><button type="button" onclick="addWordRow()" class="text-xs font-semibold bg-transparent border-none cursor-pointer" style="color:var(--color-me)">+ 新增一行</button></div></div>
        <div><label class="block text-sm font-semibold mb-1">學習筆記</label><textarea id="rf-note" rows="2" class="form-input" style="resize:none">${r.note||''}</textarea></div>`;
      }
      if(tpl==='reading'){
        // Support both old string format and new array format for quotes
        let quotes=[];
        if(Array.isArray(r.quotes))quotes=r.quotes;
        else if(r.quote)quotes=[r.quote];
        const rowCount=Math.max(quotes.length+2,3);
        let lines='';
        for(let i=0;i<rowCount;i++){
          lines+=`<div class="flex items-center gap-2 mb-1 quote-row"><span class="text-sm font-bold" style="color:var(--color-me);min-width:24px">${i+1}.</span><input type="text" data-quote-input value="${(quotes[i]||'').replace(/"/g,'&quot;')}" class="form-input flex-1" style="padding:8px 12px" placeholder="摘錄金句..." /></div>`;
        }
        return`<div><label class="block text-sm font-semibold mb-1">書名 *</label><input id="rf-book" value="${r.book||''}" class="form-input" placeholder="輸入書名..." required /></div>
        <div><label class="block text-sm font-semibold mb-1">✨ 金句</label><div id="quote-list" class="rounded-xl border p-3 max-h-[250px] overflow-y-auto" style="border-color:var(--color-me)">${lines}</div><div class="flex items-center justify-between mt-1"><p id="quote-count" class="text-xs" style="color:var(--color-green)">已輸入 ${quotes.filter(x=>x).length} 句</p><button type="button" onclick="addQuoteRowR()" class="text-xs font-semibold bg-transparent border-none cursor-pointer" style="color:var(--color-me)">+ 新增一句</button></div></div>
        <div><label class="block text-sm font-semibold mb-1">閱讀心得</label><textarea id="rf-note" rows="4" class="form-input" style="resize:vertical" placeholder="寫下你的閱讀心得與感想...">${r.note||''}</textarea></div>`;
      }
      if(tpl==='exercise')return`<div><label class="block text-sm font-semibold mb-1">運動類型</label><input id="rf-type" value="${r.type||''}" class="form-input" /></div><div><label class="block text-sm font-semibold mb-1">時長</label><input id="rf-duration" value="${r.duration||''}" class="form-input" /></div><div><label class="block text-sm font-semibold mb-1">備註</label><textarea id="rf-note" rows="2" class="form-input" style="resize:none">${r.note||''}</textarea></div>`;
      return`<div><label class="block text-sm font-semibold mb-1">備註</label><textarea id="rf-note" rows="3" class="form-input" style="resize:none">${r.note||''}</textarea></div>`;
    }

    window.addGratitudeRow=function(){
      const list=document.getElementById('gratitude-list');
      const count=list.querySelectorAll('.gratitude-row').length;
      const div=document.createElement('div');
      div.className='flex items-center gap-2 mb-1 gratitude-row';
      div.innerHTML=`<span class="text-sm font-bold" style="color:var(--color-me);min-width:24px">${count+1}.</span><input type="text" data-gratitude-input value="" class="form-input flex-1" style="padding:8px 12px" placeholder="感恩的事..." />`;
      list.appendChild(div);div.querySelector('input').focus();setupEnterNav();updateCounts();
    };
    window.addQuoteRowR=function(){
      const list=document.getElementById('quote-list');
      const count=list.querySelectorAll('.quote-row').length;
      const div=document.createElement('div');
      div.className='flex items-center gap-2 mb-1 quote-row';
      div.innerHTML=`<span class="text-sm font-bold" style="color:var(--color-me);min-width:24px">${count+1}.</span><input type="text" data-quote-input value="" class="form-input flex-1" style="padding:8px 12px" placeholder="摘錄金句..." />`;
      list.appendChild(div);div.querySelector('input').focus();setupEnterNav();updateCounts();
    };
    window.addWordRow=function(){
      const list=document.getElementById('word-list');
      const count=list.querySelectorAll('.learning-row').length;
      const div=document.createElement('div');
      div.className='flex items-center gap-2 mb-1 learning-row';
      div.innerHTML=`<span class="text-sm font-bold" style="color:var(--color-me);min-width:28px">${count+1}.</span><input type="text" data-word-input value="" class="form-input flex-1" style="padding:8px 12px" />`;
      list.appendChild(div);div.querySelector('input').focus();setupEnterNav();updateCounts();
    };

    function updateCounts(){
      const ic=document.getElementById('item-count');
      if(ic){let c=0;document.querySelectorAll('[data-gratitude-input]').forEach(el=>{if(el.value.trim())c++;});ic.textContent='已輸入 '+c+' 個';}
      const wc=document.getElementById('word-count');
      if(wc){let c=0;document.querySelectorAll('[data-word-input]').forEach(el=>{if(el.value.trim())c++;});wc.textContent='已輸入 '+c+' 個';}
      const qc=document.getElementById('quote-count');
      if(qc){let c=0;document.querySelectorAll('[data-quote-input]').forEach(el=>{if(el.value.trim())c++;});qc.textContent='已輸入 '+c+' 句';}
    }
    function setupEnterNav(){
      document.querySelectorAll('[data-gratitude-input],[data-word-input],[data-quote-input]').forEach((el,idx,all)=>{
        el.removeEventListener('keydown',el._kh);
        el._kh=e=>{if(e.key==='Enter'){e.preventDefault();if(idx+1<all.length)all[idx+1].focus();}};
        el.addEventListener('keydown',el._kh);
        el.removeEventListener('input',updateCounts);el.addEventListener('input',updateCounts);
      });
    }

    function openRM(r){
      const tpl=getTpl(habit.category);
      const today=new Date().toISOString().split('T')[0];
      const isEdit=!!r;
      document.getElementById('rf-date').value=r?.date||today;
      document.getElementById('rf-date-start').value=today;
      document.getElementById('rf-date-end').value=today;
      document.getElementById('rf-multi').checked=false;
      document.getElementById('date-single').style.display=isEdit?'':'block';
      document.getElementById('date-range').style.display='none';
      document.getElementById('rf-multi').parentElement.parentElement.style.display=isEdit?'none':'';
      updateDateCount();
      document.getElementById('record-fields').innerHTML=getFields(tpl,r);
      document.getElementById('rm-title').textContent=isEdit?'編輯記錄':'新增記錄';
      document.getElementById('record-modal').style.display='flex';
      setupEnterNav();
    }

    // Multi-date toggle
    document.getElementById('rf-multi').addEventListener('change',function(){
      const on=this.checked;
      document.getElementById('date-single').style.display=on?'none':'block';
      document.getElementById('date-range').style.display=on?'':'none';
      if(on){
        const v=document.getElementById('rf-date').value;
        document.getElementById('rf-date-start').value=v;
        document.getElementById('rf-date-end').value=v;
      }
      updateDateCount();
    });
    document.getElementById('rf-date-start').addEventListener('change',updateDateCount);
    document.getElementById('rf-date-end').addEventListener('change',updateDateCount);

    function updateDateCount(){
      const s=document.getElementById('rf-date-start').value;
      const e=document.getElementById('rf-date-end').value;
      const el=document.getElementById('date-range-count');
      if(s&&e){
        const days=Math.round((new Date(e)-new Date(s))/(86400000))+1;
        el.textContent=days>0?`將新增 ${days} 筆記錄`:'結束日期需晚於開始日期';
        el.style.color=days>0?'var(--color-green)':'var(--color-red)';
      }
    }

    function getDateList(){
      if(!document.getElementById('rf-multi').checked){
        return[document.getElementById('rf-date').value];
      }
      const s=new Date(document.getElementById('rf-date-start').value);
      const e=new Date(document.getElementById('rf-date-end').value);
      const dates=[];
      for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){
        dates.push(d.toISOString().split('T')[0]);
      }
      return dates;
    }

    window.toggleRecordCheck=async function(date){
      await SB.toggleCheckIn(habitId,date);
      const result=await SB.loadRecords(habitId);
      checkInsCache=result.checkIns||[];
      renderRecords();
    };

    window.closeRM=()=>{document.getElementById('record-modal').style.display='none';editRecordId=null;};
    document.getElementById('add-record-btn').addEventListener('click',()=>{editRecordId=null;openRM(null);});
    window.openEditR=function(id){
      editRecordId=id;
      const r=recordsCache.find(x=>x.id===id);
      openRM(r);
    };
    window.deleteR=async function(id){
      await SB.deleteRecord(id);
      await reloadRecords();renderRecords();
    };

    // Batch delete
    let batchMode=false,batchSelected=new Set();
    window.toggleBatchMode=function(){
      batchMode=!batchMode;
      batchSelected.clear();
      document.getElementById('batch-toggle').style.display=batchMode?'none':'';
      document.getElementById('batch-all').style.display=batchMode?'':'none';
      document.getElementById('batch-delete-btn').style.display=batchMode?'':'none';
      document.getElementById('batch-cancel').style.display=batchMode?'':'none';
      document.getElementById('batch-delete-btn').textContent='刪除選取 (0)';
      renderRecords();
    };
    window.toggleBatchItem=function(id){
      if(batchSelected.has(id))batchSelected.delete(id);else batchSelected.add(id);
      const btn=document.getElementById('batch-delete-btn');
      btn.textContent=`刪除選取 (${batchSelected.size})`;
      // Update checkbox visual
      const cb=document.getElementById('batch-cb-'+id);
      if(cb)cb.checked=batchSelected.has(id);
    };
    window.batchSelectAll=function(){
      const myRecs=recordsCache.filter(r=>r.isMe);
      if(batchSelected.size===myRecs.length){batchSelected.clear();}
      else{myRecs.forEach(r=>batchSelected.add(r.id));}
      document.getElementById('batch-delete-btn').textContent=`刪除選取 (${batchSelected.size})`;
      renderRecords();
    };
    window.batchDelete=async function(){
      if(!batchSelected.size)return;
      if(!confirm(`確定刪除 ${batchSelected.size} 筆記錄？`))return;
      for(const id of batchSelected){await SB.deleteRecord(id);}
      batchSelected.clear();batchMode=false;
      document.getElementById('batch-toggle').style.display='';
      document.getElementById('batch-all').style.display='none';
      document.getElementById('batch-delete-btn').style.display='none';
      document.getElementById('batch-cancel').style.display='none';
      await reloadRecords();renderRecords();
    };

    document.getElementById('record-form').addEventListener('submit',async function(e){
      e.preventDefault();
      const tpl=getTpl(habit.category);
      let content={};
      if(tpl==='reading'){
        content.book=document.getElementById('rf-book').value;
        const q=[];document.querySelectorAll('[data-quote-input]').forEach(el=>{const v=el.value.trim();if(v)q.push(v);});
        content.quotes=q;
        content.note=document.getElementById('rf-note').value;
      }
      else if(tpl==='learning'){
        const w=[];document.querySelectorAll('[data-word-input]').forEach(el=>{const v=el.value.trim();if(v)w.push(v);});
        content.topic=document.getElementById('rf-topic').value.trim();
        content.source=document.getElementById('rf-source').value.trim();
        content.words=w;content.note=document.getElementById('rf-note').value;
      }else if(tpl==='exercise'){content.type=document.getElementById('rf-type').value;content.duration=document.getElementById('rf-duration').value;content.note=document.getElementById('rf-note').value;}
      else if(tpl==='gratitude'){
        const items=[];document.querySelectorAll('[data-gratitude-input]').forEach(el=>{const v=el.value.trim();if(v)items.push(v);});
        content.items=items;content.note=document.getElementById('rf-note').value;
      }else{content.note=document.getElementById('rf-note').value;}

      if(editRecordId!==null){
        const dateVal=document.getElementById('rf-date').value;
        await SB.updateRecord(editRecordId,dateVal,content);
      }else{
        const dates=getDateList();
        for(const d of dates){
          await SB.addRecord(habitId,d,content);
        }
      }
      await reloadRecords();closeRM();renderRecords();
    });

    appInit();
  </script>
</Layout>
